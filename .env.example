# ────────────────────────────────────────────────────────────────
# QALIQ MVP — environment variables
# Copy this to .env and fill in the values for local development.
# In Railway, set these as service variables.
# ────────────────────────────────────────────────────────────────

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (PostgreSQL)
# Railway: use the DATABASE_URL injected by the Postgres plugin
DATABASE_URL=postgresql://user:password@localhost:5432/qaliq?schema=public

# Auth.js (NextAuth v5)
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Google OAuth (optional for MVP — email/password works without these)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Storage
# In dev: relative path. In Railway: mount the volume here (e.g. /data/storage)
STORAGE_PATH=./storage
STORAGE_MAX_BYTES_PER_ORG=322122547200  # 300 GB
